    RowBox[{
     FractionBox["1", "2"], 
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["q", "2"], "+", 
       RowBox[{
        SuperscriptBox["p", "2"], 
        SuperscriptBox[
         RowBox[{"Csc", "[", "\[Theta]", "]"}], "2"]}]}], ")"}]}], "+", 
